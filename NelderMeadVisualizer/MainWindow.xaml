<Window x:Class="NelderMeadVisualizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NelderMeadVisualizer"
        mc:Ignorable="d"
        Title="Метод Нелдера-Мида" Height="700" Width="1000">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="3" 
                   Text="Метод Нелдера-Мида (симплекс-метод)"
                   FontSize="18" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <!-- Левая панель -->
        <Border Grid.Row="1" Grid.Column="0" 
                BorderBrush="Gray" BorderThickness="1" CornerRadius="5" 
                Padding="10" Margin="0,0,10,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Параметры" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

                    <!-- Выбор функции -->
                    <TextBlock Text="Функция:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cmbFunction" SelectedIndex="0" Margin="0,0,0,15" Height="30">
                        <ComboBoxItem Content="Сферическая"/>
                        <ComboBoxItem Content="Розенброка"/>
                        <ComboBoxItem Content="Квадратичная"/>
                        <ComboBoxItem Content="Растригина"/>
                        <ComboBoxItem Content="Аккли"/>
                        <ComboBoxItem Content="Била"/>
                        <ComboBoxItem Content="Бута"/>
                        <ComboBoxItem Content="Гольдштейна-Прайса"/>
                        <ComboBoxItem Content="Химмельблау"/>
                    </ComboBox>

                    <Separator Margin="0,10,0,10"/>

                    <!-- Параметры метода Нелдера-Мида -->
                    <TextBlock Text="Параметры метода" FontSize="13" FontWeight="Bold" Margin="0,0,0,10"/>

                    <Border Background="#F5F5F5" CornerRadius="5" Padding="8" Margin="0,0,0,10">
                        <StackPanel>
                            <Grid Margin="0,5,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Отражение:" Grid.Column="0" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtAlpha" Text="1.0" Grid.Column="1" Margin="5,0,0,0"/>
                            </Grid>

                            <Grid Margin="0,5,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Растяжение:" Grid.Column="0" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtBeta" Text="2.0" Grid.Column="1" Margin="5,0,0,0"/>
                            </Grid>

                            <Grid Margin="0,5,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Сжатие:" Grid.Column="0" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtGamma" Text="0.5" Grid.Column="1" Margin="5,0,0,0"/>
                            </Grid>

                            <Grid Margin="0,5,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Редукция:" Grid.Column="0" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtSigma" Text="0.5" Grid.Column="1" Margin="5,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Separator Margin="0,10,0,10"/>

                    <!-- Параметры остановки -->
                    <TextBlock Text="Параметры остановки" FontSize="13" FontWeight="Bold" Margin="0,0,0,10"/>

                    <Border Background="#F5F5F5" CornerRadius="5" Padding="8" Margin="0,0,0,10">
                        <StackPanel>
                            <Grid Margin="0,5,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Точность:" Grid.Column="0" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtTolerance" Text="0.000001" Grid.Column="1" Margin="5,0,0,0"/>
                            </Grid>

                            <Grid Margin="0,5,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Макс. итераций:" Grid.Column="0" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtMaxIterations" Text="100" Grid.Column="1" Margin="5,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Separator Margin="0,10,0,10"/>

                    <!-- Начальные точки -->
                    <TextBlock Text="Начальные точки (x, y):" FontWeight="Bold" Margin="0,0,0,5"/>
                    <Border Background="#F5F5F5" CornerRadius="5" Padding="8" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Точка 1:" FontSize="11" Margin="0,0,0,3"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="txtX1" Text="2.0" Grid.Column="0"/>
                                <TextBlock Text="," Grid.Column="1" HorizontalAlignment="Center"/>
                                <TextBox x:Name="txtY1" Text="2.0" Grid.Column="2"/>
                            </Grid>

                            <TextBlock Text="Точка 2:" FontSize="11" Margin="0,0,0,3"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="txtX2" Text="3.0" Grid.Column="0"/>
                                <TextBlock Text="," Grid.Column="1" HorizontalAlignment="Center"/>
                                <TextBox x:Name="txtY2" Text="2.0" Grid.Column="2"/>
                            </Grid>

                            <TextBlock Text="Точка 3:" FontSize="11" Margin="0,0,0,3"/>
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="txtX3" Text="2.0" Grid.Column="0"/>
                                <TextBlock Text="," Grid.Column="1" HorizontalAlignment="Center"/>
                                <TextBox x:Name="txtY3" Text="3.0" Grid.Column="2"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Кнопки -->
                    <Button x:Name="btnRun" Content="Запустить" 
                            Background="#4CAF50" Foreground="White" 
                            FontWeight="Bold" Height="35" Margin="0,5,0,5"/>

                    <Button x:Name="btnStep" Content="Шаг" 
                            Background="#FF9800" Foreground="White" 
                            FontWeight="Bold" Height="35" Margin="0,5,0,5"/>

                    <Button x:Name="btnReset" Content="Сбросить" 
                            Background="#FF5722" Foreground="White" 
                            FontWeight="Bold" Height="35" Margin="0,5,0,5"/>
                    <Separator Margin="0,10,0,5"/>
                    <CheckBox x:Name="chkShowContours" Content="Показать линии уровня" 
                            Margin="5,5,5,5" IsChecked="True" Foreground="#333"/>

                    <Button x:Name="btnResetZoom" Content="Сбросить масштаб" 
                            Background="#607D8B" Foreground="White" 
                            FontWeight="Bold" Height="35" Margin="0,5,0,0"/>
                    <Button x:Name="btnResetPoints" Content="Сбросить точки" 
                            Background="#9E9E9E" Foreground="White" 
                            FontWeight="Bold" Height="35" Margin="0,5,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Центральная область с графиком -->
        <Border Grid.Row="1" Grid.Column="1" 
                BorderBrush="Gray" BorderThickness="1" CornerRadius="5" 
                Padding="5" Margin="0,0,10,0"
                Background="White">
            <Viewbox Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Canvas x:Name="SimplexCanvas" 
                        Width="500" Height="500" 
                        Background="White"
                        ClipToBounds="True"/>
            </Viewbox>
        </Border>

        <!-- Правая панель -->
        <Border Grid.Row="1" Grid.Column="2" 
                BorderBrush="Gray" BorderThickness="1" CornerRadius="5" 
                Padding="10">
            <StackPanel>
                <TextBlock Text="Результат" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

                <ScrollViewer Height="250" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="txtResult" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"/>
                </ScrollViewer>

                <Separator Margin="0,10,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="25"/>
                        <RowDefinition Height="25"/>
                        <RowDefinition Height="25"/>
                        <RowDefinition Height="25"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Статус:" Grid.Row="0" Grid.Column="0"/>
                    <TextBlock x:Name="txtStatus" Text="Готов" Grid.Row="0" Grid.Column="1"/>

                    <TextBlock Text="Итерации:" Grid.Row="1" Grid.Column="0"/>
                    <TextBlock x:Name="txtIterations" Text="-" Grid.Row="1" Grid.Column="1"/>

                    <TextBlock Text="Сходимость:" Grid.Row="2" Grid.Column="0"/>
                    <TextBlock x:Name="txtConverged" Text="-" Grid.Row="2" Grid.Column="1"/>

                    <TextBlock Text="Ошибка:" Grid.Row="3" Grid.Column="0"/>
                    <TextBlock x:Name="txtFinalError" Text="-" Grid.Row="3" Grid.Column="1"/>
                </Grid>
            </StackPanel>
        </Border>

        <StatusBar Grid.Row="2" Grid.ColumnSpan="3" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock x:Name="statusBarText" Text="Готов. Выберите функцию и нажмите 'Запустить'"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
