<Window x:Class="NelderMeadVisualizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NelderMeadVisualizer"
        mc:Ignorable="d"
        Title="Метод Нелдера-Мида" Height="700" Width="1000">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="3" 
                   Text="Метод Нелдера-Мида (симплекс-метод)"
                   FontSize="18" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <Border Grid.Row="1" Grid.Column="0" 
                BorderBrush="Gray" BorderThickness="1" CornerRadius="5" 
                Padding="10" Margin="0,0,10,0">
            <StackPanel>
                <TextBlock Text="Параметры" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

                <TextBlock Text="Функция:" FontWeight="Bold" Margin="0,0,0,5"/>
                <RadioButton x:Name="rbSphere" Content="Сферическая" IsChecked="True" Margin="15,3"/>
                <RadioButton x:Name="rbRosenbrock" Content="Розенброка" Margin="15,3"/>
                <RadioButton x:Name="rbQuadratic" Content="Квадратичная" Margin="15,3"/>
                <RadioButton x:Name="rbRastrigin" Content="Растригина" Margin="15,3,15,15"/>

                <Separator Margin="0,10,0,10"/>

                <TextBlock Text="Начальные точки:" FontWeight="Bold" Margin="0,0,0,5"/>
                <Border Background="#F0F0F0" CornerRadius="3" Padding="8" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="(2.0, 2.0)" FontSize="12"/>
                        <TextBlock Text="(3.0, 2.0)" FontSize="12"/>
                        <TextBlock Text="(2.0, 3.0)" FontSize="12"/>
                    </StackPanel>
                </Border>

                <Separator Margin="0,10,0,10"/>

                <TextBlock Text="Точность:" Margin="0,0,0,3"/>
                <TextBox x:Name="txtTolerance" Text="0,000001" Margin="0,0,0,10"/>

                <TextBlock Text="Макс. итераций:" Margin="0,0,0,3"/>
                <TextBox x:Name="txtMaxIterations" Text="100" Margin="0,0,0,15"/>

                <Button x:Name="btnRun" Content="Запустить" 
                        Background="#4CAF50" Foreground="White" 
                        FontWeight="Bold" Height="35" Margin="0,5,0,5"/>

                <Button x:Name="btnStep" Content="Шаг" 
                        Background="#FF9800" Foreground="White" 
                        FontWeight="Bold" Height="35" Margin="0,5,0,5"/>

                <Button x:Name="btnReset" Content="Сбросить" 
                        Background="#FF5722" Foreground="White" 
                        FontWeight="Bold" Height="35" Margin="0,5,0,5"/>

                <Button x:Name="btnResetZoom" Content="Сбросить масштаб" 
                        Background="#607D8B" Foreground="White" 
                        FontWeight="Bold" Height="35" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" 
                BorderBrush="Gray" BorderThickness="1" CornerRadius="5" 
                Padding="5" Margin="0,0,10,0">
            <Canvas x:Name="SimplexCanvas" 
                    Width="500" Height="500" 
                    Background="White"
                    ClipToBounds="True"/>
        </Border>

        <Border Grid.Row="1" Grid.Column="2" 
                BorderBrush="Gray" BorderThickness="1" CornerRadius="5" 
                Padding="10">
            <StackPanel>
                <TextBlock Text="Результат" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

                <ScrollViewer Height="250" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="txtResult" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"/>
                </ScrollViewer>

                <Separator Margin="0,10,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="25"/>
                        <RowDefinition Height="25"/>
                        <RowDefinition Height="25"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Статус:" Grid.Row="0" Grid.Column="0"/>
                    <TextBlock x:Name="txtStatus" Text="Готов" Grid.Row="0" Grid.Column="1"/>

                    <TextBlock Text="Итерации:" Grid.Row="1" Grid.Column="0"/>
                    <TextBlock x:Name="txtIterations" Text="-" Grid.Row="1" Grid.Column="1"/>

                    <TextBlock Text="Сходимость:" Grid.Row="2" Grid.Column="0"/>
                    <TextBlock x:Name="txtConverged" Text="-" Grid.Row="2" Grid.Column="1"/>
                </Grid>
            </StackPanel>
        </Border>

        <StatusBar Grid.Row="2" Grid.ColumnSpan="3" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock x:Name="statusBarText" Text="Готов. Выберите функцию и нажмите 'Запустить'"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
